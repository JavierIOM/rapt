# RAPT.io API Credentials
# Copy this file to .env and fill in your credentials
# These should be added as environment variables in your Netlify dashboard

RAPT_EMAIL=your-email@example.com
RAPT_API_SECRET=your-api-secret-here

# Optional: Manual Original Gravity (e.g., 1063.4 for OG 1.0634)
# Leave empty to use the first telemetry reading or profile session data
RAPT_MANUAL_OG=

# Optional: Custom Temperature Limits (°C)
# These define the temperature ranges for warnings and alerts
# Defaults shown below - adjust to your fermentation needs
TEMP_DANGER_MIN=17    # Below this is danger (red)
TEMP_WARNING_MIN=18   # Between danger and warning is orange
TEMP_WARNING_MAX=23   # Between warning min and max is good (green)
TEMP_DANGER_MAX=24    # Above this is danger (red)

# Optional: Telegram Alerts
# Leave blank to disable Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_COOLDOWN_MINUTES=60
STALL_COOLDOWN_MINUTES=360
GRAVITY_STALL_THRESHOLD=2

# Optional: Cold Crash Mode
# Set a strong password to protect the cold-crash toggle endpoint
COLD_CRASH_SECRET=

# Optional: Debug Mode (NOT RECOMMENDED FOR PRODUCTION)
# Enables verbose logging that exposes device data in function logs
# Set to 'true' only for local development/troubleshooting
DEBUG=false
